# Core app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI features
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_OCR_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=700

# Local auth
DEMO_USERS_FILE=
DEMO_AUTH_SECRET=change-me-in-demo

# Optional persistence
# Uncomment if you want persistent storage instead of local JSON fallback.
# POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/ai_healthcare
# QDRANT_URL=http://localhost:6333
# QDRANT_LOCAL_PATH=
# QDRANT_COLLECTION_PREFIX=documents

# Optional advanced integrations
# Uncomment only if you want external provider sync,
# carrier provider-directory verification, or external scheduling feeds.

